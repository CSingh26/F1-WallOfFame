# ─────────────────────────────────────────────────────────────
# F1 Heritage Explorer — Environment Variables (example)
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Public app URLs (safe to expose to the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEPLOYED_APP_URL=https://f1-wall-of-fame-mzva79dx1-csingh26s-projects.vercel.app

# Optional approved/licensed asset CDN base (public)
NEXT_PUBLIC_APPROVED_ASSET_BASE_URL=

# Data source base URLs (have safe defaults if omitted)
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
OPENF1_BASE_URL=https://api.openf1.org/v1

# Upstash Vector (semantic search). App falls back to local search if missing.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Server-only secret protecting sync routes. REQUIRED for /api/f1/sync/*
SYNC_SECRET=

# Optional: Upstash Redis cache (app works without it)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Vercel Blob storage for approved media
BLOB_READ_WRITE_TOKEN=

# Optional: Google Photos (user-authorized / self-owned media only). Not required.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_PHOTOS_ALLOWED_ALBUM_ID=
